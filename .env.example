# Database
# PostgreSQL:
DATABASE_URL="postgresql://postgres:password@localhost:5432/vpn_3x_ui?schema=public"
DB_PROVIDER="postgresql"

# SQLite (для локальной разработки):
# DATABASE_URL="file:./dev.db"
# DB_PROVIDER="sqlite"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production-min-32-chars"

# YooKassa
YOOKASSA_SHOP_ID="your_shop_id"
YOOKASSA_SECRET_KEY="your_secret_key"
YOOKASSA_RETURN_URL="http://localhost:3000/buy/success"

# 3x-ui панели (можно несколько через запятую для обычных, отдельно для VIP)
# Формат: name|url|username|password|isVip
# Пример: "Main|http://192.168.1.100:2053|admin|password|false,VIP|http://192.168.1.101:2053|admin|password|true"
XUI_PANELS=""

# Для одной панели (альтернативный вариант)
XUI_URL="http://localhost:2053"
XUI_USERNAME="admin"
XUI_PASSWORD="password"
XUI_IS_VIP="false"
